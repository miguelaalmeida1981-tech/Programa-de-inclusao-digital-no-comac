                <li><a href="paginas/tutoriais.html">📚 Tutoriais</a></li>
                <li><a href="paginas/agendamentos.html">📅 Agendamentos</a></li>
                <li><a href="paginas/noticias.html">📰 Notícias</a></li>
                <li><a href="paginas/contato.html">📞 Contato</a></li>
            </ul>
