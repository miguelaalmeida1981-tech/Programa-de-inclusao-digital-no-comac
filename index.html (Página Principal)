                <article class="card-tutorial" tabindex="0">
                    <div class="video-placeholder">
                        <span class="duracao">⏱️ 6 min</span>
                        <div class="play-button">▶️</div>
                    </div>
                    <div class="conteudo-tutorial">
                        <span class="tag-categoria">Fotos</span>
