    <!-- Header/Banner -->
    <header class="banner-principal">
        <div class="container">
            <div class="banner-conteudo">
                <h1>Bem-vindo ao COMAC</h1>
                <p class="subtitulo">Inclusão Digital para Terceira Idade</p>
                <p class="descricao">Aprenda a usar tecnologia de forma simples, segura e divertida!</p>
                <div class="botoes-banner">
