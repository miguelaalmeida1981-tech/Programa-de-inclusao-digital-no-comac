    <!-- Seção de Ajuda -->
    <section id="ajuda" class="ajuda-rapida" aria-labelledby="titulo-ajuda">
        <div class="container">
            <h2 id="titulo-ajuda" class="titulo-secao">Precisa de Ajuda?</h2>
            
            <div class="opcoes-ajuda">
                <div class="opcao-ajuda">
                    <div class="icone-ajuda">📞</div>
