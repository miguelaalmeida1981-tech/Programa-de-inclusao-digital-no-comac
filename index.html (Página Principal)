                        <button class="btn-assistir" onclick="abrirTutorial('tirar-fotos')">
                            Assistir Agora
                        </button>
                    </div>
                </article>
                
                <article class="card-tutorial" tabindex="0">
                    <div class="video-placeholder">
                        <span class="duracao">⏱️ 10 min</span>
                        <div class="play-button">▶️</div>
                    </div>
                    <div class="conteudo-tutorial">
                        <span class="tag-categoria">Segurança</span>
