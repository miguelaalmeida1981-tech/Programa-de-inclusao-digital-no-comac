                        <div class="play-button">▶️</div>
                    </div>
                    <div class="conteudo-tutorial">
                        <span class="tag-categoria">WhatsApp</span>
                        <h3>Como Enviar Mensagens</h3>
                        <p>Aprenda a enviar mensagens de texto e áudio pelo WhatsApp.</p>
                        <button class="btn-assistir" onclick="abrirTutorial('whatsapp-mensagens')">
                            Assistir Agora
                        </button>
                    </div>
                </article>
                
                <article class="card-tutorial" tabindex="0">
                    <div class="video-placeholder">
                        <span class="duracao">⏱️ 8 min</span>
                        <div class="play-button">▶️</div>
                    </div>
                    <div class="conteudo-tutorial">
                        <span class="tag-categoria">Videochamada</span>
