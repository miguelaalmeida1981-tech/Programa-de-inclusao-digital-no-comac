                    <a href="tel:+5500000000000" class="btn-telefone">(00) 00000-0000</a>
                </div>
                
                <div class="opcao-ajuda">
                    <div class="icone-ajuda">💬</div>
                    <h3>WhatsApp</h3>
                    <p>Mande uma mensagem e respondemos rapidinho!</p>
                    <a href="https://wa.me/5500000000000" class="btn-whatsapp" target="_blank">
                        💬 Falar no WhatsApp
                    </a>
                </div>
                
                <div class="opcao-ajuda">
                    <div class="icone-ajuda">📧</div>
                    <h3>E-mail</h3>
                    <p>Envie suas dúvidas por e-mail.</p>
                    <a href="mailto:ajuda@comac.org.br" class="btn-email">
                        ✉️ ajuda@comac.org.br
                    </a>
                </div>
            </div>
        </div>
