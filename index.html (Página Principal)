        <div class="container">
            <h2 id="titulo-servicos" class="titulo-secao">Nossos Serviços</h2>
            
            <div class="grade-servicos">
                <article class="cartao-servico" tabindex="0">
                    <div class="icone-servico">💻</div>
                    <h3>Aulas de Informática</h3>
                    <p>Aulas presenciais para aprender desde o básico até atividades do dia a dia, como usar WhatsApp, fazer videochamadas e muito mais.</p>
                    <a href="paginas/tutoriais.html" class="btn-card">Saiba Mais →</a>
                </article>
                
                <article class="cartao-servico" tabindex="0">
                    <div class="icone-servico">📱</div>
                    <h3>Suporte com Celular</h3>
                    <p>Aprenda a usar seu smartphone de forma segura. Enviamos mensagens, tirar fotos, fazer chamadas de vídeo com família.</p>
                    <a href="paginas/tutoriais.html#celular" class="btn-card">Saiba Mais →</a>
                </article>
                
                <article class="cartao-servico" tabindex="0">
                    <div class="icone-servico">🌐</div>
                    <h3>Internet Segura</h3>
                    <p>Aprenda a navegar na internet com segurança, identificar golpes e proteger seus dados pessoais.</p>
                    <a href="paginas/tutoriais.html#seguranca" class="btn-card">Saiba Mais →</a>
                </article>
                
                <article class="cartao-servico" tabindex="0">
                    <div class="icone-servico">📅</div>
                    <h3>Agendamentos Online</h3>
                    <p>Ajuda para marcar consultas médicas, agendar serviços e resolver pendências pela internet.</p>
                    <a href="paginas/agendamentos.html" class="btn-card">Agendar Agora →</a>
                </article>
            </div>
        </div>
    </section>

    <!-- Seção de Tutoriais Rápidos -->
    <section class="tutoriais-rapidos" aria-labelledby="titulo-tutoriais">
        <div class="container">
            <h2 id="titulo-tutoriais" class="titulo-secao">Tutoriais Mais Buscados</h2>
            
